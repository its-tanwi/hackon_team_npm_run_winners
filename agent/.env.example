# Copy this file to .env and fill in your key.
# Get a free Gemini API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# (Optional) Override the chat model used by all three subagents.
# Default: gemini-2.5-flash. Useful when you hit a free-tier daily quota
# on one model and want to switch buckets without code changes.
# GEMINI_MODEL=gemini-2.0-flash-lite

# (Optional) Override the embedding model used by the catalog semantic
# retriever. Default: gemini-embedding-001.
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
